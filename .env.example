# ── Model Provider (pick one) ──────────────────────────────────────────────
MODEL_PROVIDER=groq             # options: groq | mistral | openai | anthropic | bedrock | gemini | ollama
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile   # or: mixtral-8x7b-32768 | gemma2-9b-it | llama-3.1-8b-instant
# MISTRAL_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# AWS_BEDROCK_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434  # for local Mistral via Ollama

# ── White-label Client Config ──────────────────────────────────────────────
CLIENT_NAME=MyBrand
CLIENT_INDUSTRY=SaaS
CLIENT_TONE=professional        # professional | casual | witty
CLIENT_LANGUAGE=en

# ── LinkedIn ───────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_LEAD_SEARCH_KEYWORDS=startup founder,CTO,Head of Marketing
LINKEDIN_DAILY_CONNECTION_LIMIT=20

# ── Instagram ──────────────────────────────────────────────────────────────
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── TikTok ─────────────────────────────────────────────────────────────────
TIKTOK_SESSION_ID=

# ── Facebook ───────────────────────────────────────────────────────────────
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── WhatsApp (Twilio) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Email (SendGrid) ───────────────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=hello@yourdomain.com

# ── Calendly ───────────────────────────────────────────────────────────────
CALENDLY_API_KEY=
CALENDLY_EVENT_URL=https://calendly.com/yourname/30min

# ── Memory / Vector Store ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/memory
BUSINESS_DATA_DIR=./data/business
